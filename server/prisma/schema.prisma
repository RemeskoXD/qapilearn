generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QhubUser {
  id               String                @id @default(cuid())
  email            String                @unique
  passwordHash     String
  name             String?
  phone            String?
  role             String                @default("student")
  positions        Json                  @default("[]")
  level            Int                   @default(1)
  xp               Int                   @default(0)
  xpBoostUntil     DateTime?
  planExpires      DateTime?
  isBanned         Boolean               @default(false)
  bio              String?
  avatarUrl        String?
  isPublicProfile  Boolean               @default(false)
  financialProfit  Float                 @default(0)
  inventory        Json                  @default("[]")
  activeChallenges Json                  @default("[]")
  certificates     Json                  @default("[]")
  courseProgress   Json                  @default("[]")
  lessonNotes      Json                  @default("{}")
  quizHistory      Json                  @default("[]")
  adminNotes       Json                  @default("[]")
  profitHistory    Json                  @default("[]")
  messages         Json                  @default("[]")
  dashboardMessage Json?
  joinDate         DateTime              @default(now())
  lastLogin        DateTime              @default(now())
  region           String                @default("Karlovy Vary")
  submissions      QhubBonusSubmission[]
  bookings         QhubBooking[]
  tickets          QhubTicket[]

  @@map("qhub_users")
}

model QhubCourse {
  id             String   @id @default(cuid())
  title          String
  description    String
  image          String
  level          String   @default("student")
  author         String
  totalDuration  Int      @default(0)
  published      Boolean  @default(false)
  xpReward       Int      @default(0)
  learningPoints Json     @default("[]")
  modules        Json     @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("qhub_courses")
}

model QhubQuiz {
  id           String   @id @default(cuid())
  title        String
  description  String
  image        String
  level        String   @default("student")
  xpReward     Int      @default(0)
  passingScore Int      @default(70)
  published    Boolean  @default(true)
  questions    Json     @default("[]")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("qhub_quizzes")
}

model QhubMentor {
  id                String        @id @default(cuid())
  name              String
  role              String
  image             String
  bio               String
  hourlyRate        Float         @default(0)
  isAvailable       Boolean       @default(true)
  nextAvailableDate DateTime?
  bookings          QhubBooking[]

  @@map("qhub_mentors")
}

model QhubBooking {
  id          String     @id @default(cuid())
  mentorId    String
  userId      String
  userEmail   String
  date        DateTime
  status      String     @default("pending")
  note        String     @default("")
  meetingLink String?
  adminNote   String?
  rating      Int?
  createdAt   DateTime   @default(now())
  mentor      QhubMentor @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  user        QhubUser   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("qhub_bookings")
}

model QhubCalendarEvent {
  id                String   @id @default(cuid())
  title             String
  description       String
  date              DateTime
  type              String   @default("webinar")
  link              String?
  registeredUserIds Json     @default("[]")
  maxAttendees      Int?
  price             Float?
  isFreeForVip      Boolean  @default(false)
  isFreeForPremium  Boolean  @default(false)

  @@map("qhub_events")
}

model QhubStream {
  id          String   @id @default(cuid())
  title       String
  description String
  thumbnail   String
  streamUrl   String
  date        DateTime
  status      String   @default("upcoming")
  viewers     Int      @default(0)

  @@map("qhub_streams")
}

model QhubEbook {
  id          String @id @default(cuid())
  title       String
  description String
  coverImage  String
  downloadUrl String
  pages       Int    @default(0)
  author      String

  @@map("qhub_ebooks")
}

model QhubTicket {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  subject   String
  status    String   @default("open")
  priority  String   @default("medium")
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  user      QhubUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("qhub_tickets")
}

model QhubBonusTask {
  id          String    @id @default(cuid())
  title       String
  description String
  rewardXP    Int       @default(0)
  deadline    DateTime?
  proofType   String    @default("text")

  @@map("qhub_bonus_tasks")
}

model QhubBonusSubmission {
  id          String   @id @default(cuid())
  taskId      String
  userId      String
  content     String
  status      String   @default("pending")
  submittedAt DateTime @default(now())
  user        QhubUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("qhub_bonus_submissions")
}

model QhubArtifact {
  id             String  @id @default(cuid())
  name           String
  description    String
  image          String
  rarity         String  @default("common")
  type           String  @default("consumable")
  quantity       Int     @default(0)
  price          Int?
  effectType     String?
  effectDuration Int?

  @@map("qhub_artifacts")
}

model QhubChallenge {
  id               String  @id @default(cuid())
  title            String
  description      String
  type             String  @default("daily")
  targetCount      Int     @default(1)
  rewardXP         Int     @default(0)
  rewardArtifactId String?

  @@map("qhub_challenges")
}

model QhubCommunitySession {
  id           String   @id @default(cuid())
  hostUserId   String
  hostName     String
  topic        String
  date         DateTime
  description  String
  maxAttendees Int      @default(50)
  attendees    Json     @default("[]")

  @@map("qhub_community_sessions")
}

model QhubLevel {
  level      Int    @id
  xpRequired Int
  title      String

  @@map("qhub_levels")
}

model QhubSystemSettings {
  id                 Int     @id @default(1)
  maintenanceMode    Boolean @default(false)
  allowRegistrations Boolean @default(true)
  globalBanner       String  @default("")
  version            String  @default("1.0.0 Q-Hub")

  @@map("qhub_settings")
}
