# ─── Q-Hub backend environment ─────────────────────────────────────────────
# Lokálně: zkopíruj jako server/.env a vyplň hodnoty.
# Coolify: tyto proměnné nastav v Environment Variables u aplikace.
# ──────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Q-Hub backend)
# Příklad: postgresql://uzivatel:heslo@host:5432/databaze?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Tajný klíč pro JWT (POVINNÉ – vygeneruj náhodný 64+ znakový řetězec)
#   Linux/Mac:  openssl rand -hex 64
#   PowerShell: -join ((1..128) | %{ '{0:x}' -f (Get-Random -Max 16) })
JWT_SECRET="ZMEN-MNE-NA-NAHODNY-RETEZEC-MIN-64-ZNAKU"

# Port API serveru (Coolify obvykle 4000)
PORT=4000

# Vývoj:    URL Vite serveru, aby fungoval CORS (např. http://localhost:5173)
# Produkce: nech "" – frontend běží ze stejného originu jako API.
CLIENT_ORIGIN=""

# Prostředí: development | production (Coolify = production)
NODE_ENV=production

# Admin emaily (čárkami oddělené) – tito uživatelé jsou po loginu povýšeni na admin role.
ADMIN_EMAILS=""

# Tajné heslo pro přístup k validaci databáze
DB_CHECK_SECRET="qhubsecret"

